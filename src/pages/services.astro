---
import MainLayout from "../layouts/MainLayout.astro";

// ── Service menu - mirrors SomaRenew's live Pabau booking categories ──────
// Source of truth: partner.pabau.com/online-bookings/soma-renew-medical
// Keep names/prices in sync with Pabau whenever the clinic updates them.
const categories = [
  {
    n: "I",
    name: "Body Contouring & Fat Reduction",
    eyebrow: "Body Sculpting",
    blurb: "Non-invasive fat reduction and muscle sculpting, with zero downtime.",
    layout: "cards",
    cols: "sm:grid-cols-2 lg:grid-cols-3",
    services: [
      { name: "CoolSculpting - Single Cycle", dur: "60 min", price: 650 },
      { name: "U-Shape 2 - Body Sculpting Session", dur: "60 min", price: 175 },
      { name: "CoolSculpting + U-Shape 2 Combo", dur: "75 min", price: 775 },
    ],
  },
  {
    n: "II",
    name: "GLP-1 & Medical Weight Loss",
    eyebrow: "Weight Loss",
    blurb: "Physician-supervised GLP-1 therapy, prescribed and monitored month to month.",
    layout: "list",
    services: [
      { name: "GLP-1 Consultation & Prescription", dur: "45 min", price: 199 },
      { name: "GLP-1 Medication (Monthly)", dur: "30 min", price: 299 },
      { name: "Body Composition Analysis", dur: "10 min", price: 35 },
    ],
  },
  {
    n: "III",
    name: "Nutrition Counseling",
    eyebrow: "Nutrition",
    blurb: "One-to-one guidance to make your results sustainable.",
    layout: "list",
    services: [
      { name: "Initial Nutrition Assessment", dur: "60 min", price: 149 },
      { name: "Follow-Up Nutrition Session", dur: "30 min", price: 75 },
    ],
  },
  {
    n: "IV",
    name: "IV Hydration Therapy",
    eyebrow: "Infusions",
    blurb: "Targeted drips and boosters to replenish, recover and renew.",
    layout: "list",
    services: [
      { name: "Slim & Burn Drip", dur: "45 min", price: 149 },
      { name: "Recovery & Replenish Drip", dur: "45 min", price: 129 },
      { name: "NAD+ Booster Shot", dur: "5 min", price: 49 },
    ],
  },
  {
    n: "V",
    name: "Peptide Therapy - Injectable",
    eyebrow: "Advanced Therapies",
    blurb: "Clinician-guided peptide protocols for recovery, performance and longevity.",
    layout: "list",
    services: [
      { name: "BPC-157", dur: "30 min", price: 149 },
      { name: "CJC-1295 / Ipamorelin", dur: "30 min", price: 199 },
      { name: "AOD-9604", dur: "30 min", price: 179 },
      { name: "Tesamorelin", dur: "30 min", price: 249 },
      { name: "Thymosin Alpha-1", dur: "30 min", price: 199 },
      { name: "Melanotan II", dur: "30 min", price: 149 },
      { name: "MOTS-c", dur: "30 min", price: 229 },
      { name: "Semax / Selank", dur: "30 min", price: 159 },
      { name: "Epitalon", dur: "30 min", price: 179 },
      { name: "SS-31", dur: "30 min", price: 199 },
      { name: "HCG", dur: "30 min", price: 149 },
      { name: "NAD+ Injectable", dur: "30 min", price: 169 },
      { name: "LL-37", dur: "30 min", price: 189 },
      { name: "GHK-Cu (Copper Peptide)", dur: "30 min", price: 149 },
    ],
  },
  {
    n: "VI",
    name: "Peptide Therapy - Nasal Sprays",
    eyebrow: "Advanced Therapies",
    blurb: "The convenience of daily peptide support, without the needle.",
    layout: "list",
    services: [
      { name: "BPC-157 / TB-500 Nasal Spray", dur: "5 min", price: 129 },
      { name: "CJC-1295 / Ipamorelin Nasal Spray", dur: "5 min", price: 169 },
      { name: "Selank Nasal Spray", dur: "5 min", price: 129 },
      { name: "NAD+ / Methylene Blue Nasal Spray", dur: "5 min", price: 149 },
      { name: "NAD+ Nasal Spray", dur: "5 min", price: 99 },
    ],
  },
  {
    n: "VII",
    name: "Signature Packages",
    eyebrow: "Programs",
    blurb: "Multi-month, all-in transformation programs for committed results.",
    layout: "cards",
    cols: "sm:grid-cols-2",
    services: [
      { name: "Starter Sculpt - 30-Day Jumpstart", dur: "60 min", price: 799 },
      { name: "Transform - 90-Day Program", dur: "60 min", price: 3199 },
      { name: "Elite Body Reset - 6-Month Membership", dur: "60 min", price: 6999 },
      { name: "Peptide Performance - Monthly Wellness Plan", dur: "30 min", price: 599 },
    ],
  },
];

const fmt = (n: number) => n.toLocaleString("en-US");
---

<MainLayout title="Services">
  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <section class="bg-bone">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="flex items-center justify-between py-4 border-b border-line font-mono text-[0.62rem] sm:text-[0.68rem] tracking-[0.18em] uppercase text-ink/45">
        <span>The Service Menu</span>
        <span class="hidden sm:inline">Physician-supervised</span>
        <span>Naperville, IL</span>
      </div>

      <div class="grid lg:grid-cols-12 gap-y-8 lg:gap-x-16 items-end pt-14 md:pt-20 pb-16">
        <div class="lg:col-span-8">
          <p class="label reveal mb-7">
            <span class="inline-block w-9 h-px bg-gold/60"></span> Curated Wellness
          </p>
          <h1 class="reveal d-1 font-serif text-ink leading-[0.95] text-[clamp(3rem,13vw,3.75rem)] sm:text-7xl xl:text-[6rem]">
            Everything we<br /><span class="accent-word">offer, in full.</span>
          </h1>
        </div>
        <div class="lg:col-span-4">
          <p class="reveal d-2 text-secondary-text leading-relaxed mb-6">
            Transparent pricing, booked directly through our secure portal. Every
            plan is tailored in consultation; the figures below are starting points.
          </p>
          <p class="reveal d-2 font-mono text-[0.68rem] tracking-[0.12em] uppercase text-ink/50 leading-relaxed">
            Physician supervised &nbsp;·&nbsp; Personalized plans &nbsp;·&nbsp; FDA-approved
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CATEGORY SECTIONS ═════════════════════════════════════════════ -->
  {categories.map((cat, ci) => (
    <section class={`section border-t border-line ${ci % 2 === 0 ? "bg-cream" : "bg-bone"}`}>
      <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
        <div class="grid lg:grid-cols-12 gap-y-10 lg:gap-x-16">
          <!-- Sticky header -->
          <div class="lg:col-span-4">
            <div class="lg:sticky lg:top-32">
              <p class="index-label reveal"><span class="num">{cat.n}</span> &nbsp;·&nbsp;{cat.eyebrow}</p>
              <div class="reveal-line h-px bg-line mt-5 mb-8"></div>
              <h2 class="reveal d-1 font-serif text-4xl md:text-5xl text-ink leading-[1.04]">{cat.name}</h2>
              <p class="reveal d-2 mt-5 text-secondary-text leading-relaxed max-w-xs">{cat.blurb}</p>
              <a href="/consultation" class="link-arrow reveal d-2 mt-7">
                Book in this category
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
              </a>
            </div>
          </div>

          <!-- Content -->
          <div class="lg:col-span-8">
            {cat.layout === "cards" ? (
              <div class={`grid gap-5 ${cat.cols}`}>
                {cat.services.map((s, i) => (
                  <div class={`edit-card reveal d-${(i % 3) + 1} p-7 flex flex-col`}>
                    <h3 class="font-serif text-2xl text-ink leading-tight">{s.name}</h3>
                    <span class="font-mono text-[0.6rem] tracking-[0.14em] uppercase text-secondary-text mt-3">{s.dur}</span>
                    <div class="mt-6 flex items-baseline gap-1 flex-1">
                      <span class="font-serif text-lg text-gold-deep font-medium">$</span>
                      <span class="font-serif text-4xl md:text-5xl text-ink leading-none">{fmt(s.price)}</span>
                    </div>
                    <a href="/consultation" class="btn-secondary w-full mt-7">Book</a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="reveal border-t border-line">
                {cat.services.map((s) => (
                  <a href="/consultation" class="menu-row group flex items-baseline gap-2 py-4 border-b border-line">
                    <span class="font-serif text-lg sm:text-xl text-ink group-hover:text-gold-deep transition-colors">{s.name}</span>
                    <span class="hidden sm:inline font-mono text-[0.56rem] tracking-[0.12em] uppercase text-secondary-text/60 ml-2 whitespace-nowrap">{s.dur}</span>
                    <span class="flex-1 border-b border-dotted border-line mx-2 -translate-y-[3px]"></span>
                    <span class="font-serif text-lg sm:text-xl text-ink whitespace-nowrap"><span class="text-sm text-gold-deep">$</span>{fmt(s.price)}</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ══ CLOSING ═══════════════════════════════════════════════════════ -->
  <section class="on-dark relative bg-ink text-cream overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[var(--soma-gold)]/40 to-transparent"></div>
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 section text-center">
      <p class="label label--light reveal justify-center mb-7">Not sure where to start?</p>
      <h2 class="reveal d-1 font-serif text-5xl md:text-6xl lg:text-7xl text-cream leading-[1] max-w-3xl mx-auto">
        Tell us your goals.<br />We'll build the <span class="accent-word accent-word--light">plan.</span>
      </h2>
      <p class="reveal d-2 mt-8 max-w-xl mx-auto text-cream/55 text-lg leading-relaxed">
        A complimentary consultation is the fastest way to the right protocol.
        No pressure, no guesswork.
      </p>
      <div class="reveal d-2 mt-10 flex justify-center">
        <a href="/consultation" class="btn-gold">Schedule My Consultation</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .menu-row { transition: transform 0.3s ease; }
  .menu-row:hover { transform: translateX(4px); }
</style>
