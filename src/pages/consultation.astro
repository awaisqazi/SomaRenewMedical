---
import MainLayout from "../layouts/MainLayout.astro";

const bookingUrl =
  "https://partner.pabau.com/online-bookings/soma-renew-medical?location=24088&staff=115036&fallback=true";

const treatmentGroups = [
  "Body Contouring & Fat Reduction",
  "GLP-1 & Medical Weight Loss",
  "Nutrition Counseling",
  "IV Hydration Therapy",
  "Peptide Therapy - Injectable",
  "Peptide Therapy - Nasal Sprays",
  "Signature Packages",
];
---

<MainLayout title="Reserve Your Experience">
  <section class="booking-page">
    <div class="booking-container">
      <div class="booking-masthead">
        <span>Secure Booking</span>
        <span class="hidden sm:inline">Pabau · Encrypted</span>
        <span>Naperville, IL</span>
      </div>

      <header class="booking-header">
        <div class="booking-copy">
          <p class="booking-overline">
            <span class="overline-tick"></span> Reserve Your Experience
          </p>
          <h1>Book in one<br /><span class="accent-word">secure flow.</span></h1>
          <p class="booking-lede">
            Physician-guided weight loss, body sculpting, peptide therapy, IV
            hydration and wellness packages, all in a single, encrypted booking
            flow.
          </p>
        </div>

        <div class="booking-actions" aria-label="Booking assistance links">
          <a class="booking-action booking-action-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
            <span>Open in New Tab</span>
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="M7 17L17 7M17 7H8M17 7V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          <a class="booking-action booking-action-secondary" href="tel:+16305550150">
            <span>Call the Clinic</span>
          </a>
        </div>
      </header>

      <ul class="treatment-strip" aria-label="Treatment menu categories">
        {treatmentGroups.map((group) => <li>{group}</li>)}
      </ul>

      <div class="booking-shell" data-booking-shell>
        <div class="booking-shell-bar">
          <div class="booking-shell-title">
            <span aria-hidden="true"></span>
            Pabau Booking
          </div>
          <div>Naperville, IL</div>
        </div>

        <div class="booking-loading" aria-hidden="true">
          <div class="loading-spinner"></div>
          <span>Preparing secure booking</span>
        </div>

        <iframe
          src={bookingUrl}
          width="100%"
          height="100%"
          class="booking-frame"
          title="Reserve Your Wellness Experience"
          loading="eager"
          referrerpolicy="strict-origin-when-cross-origin"
          data-booking-frame
        ></iframe>
      </div>

      <footer class="booking-assistance" aria-label="Booking support">
        <span>Need a hand?</span>
        <a href="tel:+16305550150">(630) 555-0150</a>
        <a href="mailto:contact@somarenewmedical.com">contact@somarenewmedical.com</a>
      </footer>
    </div>
  </section>

  <style>
    .booking-page {
      background: var(--bone);
      min-height: calc(100svh - 84px);
      padding: clamp(1rem, 2.5vw, 2rem) clamp(1rem, 4vw, 2rem) 2rem;
    }

    .booking-container {
      margin: 0 auto;
      width: min(100%, 1400px);
    }

    .booking-masthead {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 0 0.9rem;
      border-bottom: 1px solid var(--line);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 0.64rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(27, 34, 39, 0.45);
    }

    .booking-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      gap: 1.5rem;
      margin: 1.6rem 0 1.4rem;
    }

    .booking-overline {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      color: var(--gold-deep);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 0.9rem;
    }
    .overline-tick {
      width: 2rem;
      height: 1px;
      background: rgba(192, 178, 131, 0.6);
      display: inline-block;
    }

    .booking-copy h1 {
      color: var(--ink);
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2.4rem, 5vw, 4.25rem);
      line-height: 0.98;
      margin: 0;
    }

    .booking-lede {
      color: var(--secondary-text);
      font-size: clamp(0.96rem, 1.6vw, 1.1rem);
      line-height: 1.65;
      margin: 1rem 0 0;
      max-width: 640px;
    }

    .booking-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      justify-content: flex-end;
    }

    .booking-action {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      min-height: 50px;
      padding: 0 1.4rem;
      border-radius: 2px;
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 0.74rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      white-space: nowrap;
      transition: transform 200ms ease, background 200ms ease, border-color 200ms ease, color 200ms ease;
    }
    .booking-action:hover { transform: translateY(-2px); }
    .booking-action svg { height: 0.95rem; width: 0.95rem; }

    .booking-action-primary {
      background: var(--ink);
      color: var(--cream);
      border: 1px solid var(--ink);
    }
    .booking-action-primary:hover { background: var(--gold-deep); border-color: var(--gold-deep); }

    .booking-action-secondary {
      background: transparent;
      border: 1px solid var(--line-strong);
      color: var(--ink);
    }
    .booking-action-secondary:hover { border-color: var(--ink); }

    .treatment-strip {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      list-style: none;
      margin: 0 0 1.2rem;
      padding: 0 0 0.2rem;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .treatment-strip::-webkit-scrollbar { display: none; }
    .treatment-strip li {
      flex: 0 0 auto;
      background: var(--cream);
      border: 1px solid var(--line);
      border-radius: 999px;
      color: rgba(27, 34, 39, 0.75);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      line-height: 1;
      padding: 0.62rem 0.85rem;
      text-transform: uppercase;
    }

    .booking-shell {
      position: relative;
      background: var(--ink);
      border: 1px solid var(--line-strong);
      border-radius: 4px;
      box-shadow: 0 40px 90px -55px rgba(27, 34, 39, 0.5);
      height: clamp(700px, calc(100svh - 250px), 960px);
      min-height: 700px;
      overflow: hidden;
    }

    .booking-shell-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 40px;
      padding: 0 1rem;
      background: var(--charcoal-deep);
      border-bottom: 1px solid rgba(192, 178, 131, 0.2);
      color: rgba(243, 239, 230, 0.7);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .booking-shell-title { display: inline-flex; align-items: center; gap: 0.55rem; }
    .booking-shell-title span {
      width: 0.42rem; height: 0.42rem;
      background: var(--soma-gold);
      border-radius: 999px;
      box-shadow: 0 0 0 4px rgba(192, 178, 131, 0.16);
    }

    .booking-frame {
      position: relative;
      z-index: 2;
      width: 100%;
      height: calc(100% - 40px);
      border: 0;
      background: #fff;
    }

    .booking-loading {
      position: absolute;
      inset: 40px 0 0;
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.9rem;
      background: linear-gradient(180deg, #fff 0%, var(--cream) 100%);
      color: var(--secondary-text);
      transition: opacity 220ms ease;
      pointer-events: none;
    }
    .booking-loading span {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 0.66rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .booking-shell.is-loaded .booking-loading { opacity: 0; visibility: hidden; }

    .loading-spinner {
      width: 34px; height: 34px;
      border: 2px solid rgba(192, 178, 131, 0.18);
      border-top-color: var(--gold-deep);
      border-radius: 50%;
      animation: spin 1.1s cubic-bezier(0.5, 0, 0.5, 1) infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .booking-assistance {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 0.6rem 1.5rem;
      padding: 1.2rem 0 0;
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--secondary-text);
    }
    .booking-assistance span { opacity: 0.6; }
    .booking-assistance a { color: var(--ink); text-decoration: none; transition: color 180ms ease; }
    .booking-assistance a:hover { color: var(--gold-deep); }

    @media (max-width: 860px) {
      .booking-header { grid-template-columns: 1fr; }
      .booking-actions { justify-content: flex-start; }
    }
    @media (max-width: 640px) {
      .booking-actions { display: grid; grid-template-columns: 1fr 1fr; width: 100%; }
      .booking-action { justify-content: center; padding: 0 0.75rem; }
      .booking-shell { height: 76svh; min-height: 620px; }
      .booking-assistance { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <script>
    const bookingFrame = document.querySelector("[data-booking-frame]");
    const bookingShell = document.querySelector("[data-booking-shell]");
    const reveal = () => bookingShell?.classList.add("is-loaded");
    bookingFrame?.addEventListener("load", reveal, { once: true });
    window.setTimeout(reveal, 3200);
  </script>
</MainLayout>
