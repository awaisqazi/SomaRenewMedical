---
import MainLayout from "../layouts/MainLayout.astro";

const bookingUrl =
  "https://partner.pabau.com/online-bookings/soma-renew-medical?location=24088&staff=115036&fallback=true";

const treatmentGroups = [
  "Body Contouring",
  "Medical Weight Loss",
  "Nutrition",
  "IV Hydration",
  "Injectable Peptides",
  "Nasal Sprays",
  "Signature Packages",
];
---

<MainLayout title="Reserve Your Experience">
  <section class="booking-page">
    <div class="booking-container">
      <header class="booking-header">
        <div class="booking-copy">
          <p class="booking-overline">SomaRenew Medical Services Menu</p>
          <h1>Reserve Your Experience</h1>
          <p>
            Physician-guided weight loss, body sculpting, peptide therapy, IV
            hydration, and wellness packages in one secure booking flow.
          </p>
        </div>

        <div class="booking-actions" aria-label="Booking assistance links">
          <a class="booking-action booking-action-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
            <span>Open Booking</span>
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="M7 17L17 7M17 7H8M17 7V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          <a class="booking-action booking-action-secondary" href="tel:+13105550123">
            <span>Call Clinic</span>
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="M5.6 4.5L8.3 3.9C9 3.8 9.6 4.1 9.9 4.7L11.1 7.5C11.4 8.1 11.2 8.8 10.7 9.2L9.4 10.3C10.3 12.1 11.8 13.7 13.7 14.6L14.8 13.3C15.2 12.8 15.9 12.6 16.5 12.9L19.3 14.1C19.9 14.4 20.2 15 20.1 15.7L19.5 18.4C19.4 19.1 18.8 19.5 18.1 19.5C10.6 19.5 4.5 13.4 4.5 5.9C4.5 5.2 4.9 4.6 5.6 4.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </header>

      <ul class="treatment-strip" aria-label="Treatment menu categories">
        {treatmentGroups.map((group) => <li>{group}</li>)}
      </ul>

      <div class="booking-shell" data-booking-shell>
        <div class="booking-shell-bar">
          <div class="booking-shell-title">
            <span aria-hidden="true"></span>
            Pabau Booking
          </div>
          <div>Naperville, IL</div>
        </div>

        <div class="booking-loading" aria-hidden="true">
          <div class="loading-spinner"></div>
          <span>Preparing secure booking</span>
        </div>

        <iframe
          src={bookingUrl}
          width="100%"
          height="100%"
          class="booking-frame"
          title="Reserve Your Wellness Experience"
          loading="eager"
          referrerpolicy="strict-origin-when-cross-origin"
          data-booking-frame
        ></iframe>
      </div>

      <footer class="booking-assistance" aria-label="Booking support">
        <span>Questions?</span>
        <a href="tel:+13105550123">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M5.6 4.5L8.3 3.9C9 3.8 9.6 4.1 9.9 4.7L11.1 7.5C11.4 8.1 11.2 8.8 10.7 9.2L9.4 10.3C10.3 12.1 11.8 13.7 13.7 14.6L14.8 13.3C15.2 12.8 15.9 12.6 16.5 12.9L19.3 14.1C19.9 14.4 20.2 15 20.1 15.7L19.5 18.4C19.4 19.1 18.8 19.5 18.1 19.5C10.6 19.5 4.5 13.4 4.5 5.9C4.5 5.2 4.9 4.6 5.6 4.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          (310) 555-0123
        </a>
        <a href="mailto:contact@somarenew.com">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M4.5 6.75H19.5V17.25H4.5V6.75Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
            <path d="M5.25 7.5L12 12.25L18.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          contact@somarenew.com
        </a>
      </footer>
    </div>
  </section>

  <style>
    .booking-page {
      background:
        linear-gradient(180deg, rgba(253, 253, 253, 0.96) 0%, rgba(248, 246, 240, 0.98) 52%, #fdfdfd 100%),
        var(--warm-white);
      min-height: calc(100svh - 80px);
      padding: clamp(0.75rem, 2vw, 1.5rem);
    }

    .booking-container {
      margin: 0 auto;
      width: min(100%, 1440px);
    }

    .booking-header {
      align-items: end;
      display: grid;
      gap: 1.25rem;
      grid-template-columns: minmax(0, 1fr) auto;
      margin-bottom: 1rem;
    }

    .booking-copy {
      max-width: 900px;
    }

    .booking-overline {
      color: var(--soma-gold);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      margin-bottom: 0.45rem;
      text-transform: uppercase;
    }

    .booking-copy h1 {
      color: var(--charcoal);
      font-size: clamp(2rem, 4vw, 3.25rem);
      margin: 0;
    }

    .booking-copy p:not(.booking-overline) {
      color: var(--secondary-text);
      font-size: clamp(0.96rem, 1.7vw, 1.1rem);
      line-height: 1.65;
      margin: 0.55rem 0 0;
      max-width: 840px;
    }

    .booking-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      justify-content: flex-end;
    }

    .booking-action {
      align-items: center;
      border-radius: 999px;
      display: inline-flex;
      font-size: 0.88rem;
      font-weight: 700;
      gap: 0.55rem;
      min-height: 44px;
      padding: 0.78rem 1rem;
      text-decoration: none;
      transition:
        background-color 180ms ease,
        border-color 180ms ease,
        color 180ms ease,
        transform 180ms ease;
      white-space: nowrap;
    }

    .booking-action:hover {
      transform: translateY(-1px);
    }

    .booking-action svg,
    .booking-assistance svg {
      height: 1rem;
      width: 1rem;
    }

    .booking-action-primary {
      background: var(--soma-gold);
      color: var(--charcoal);
    }

    .booking-action-primary:hover {
      background: #d4c89a;
    }

    .booking-action-secondary {
      background: rgba(255, 255, 255, 0.68);
      border: 1px solid rgba(192, 178, 131, 0.38);
      color: var(--charcoal);
    }

    .booking-action-secondary:hover {
      border-color: rgba(192, 178, 131, 0.7);
      color: var(--soma-gold);
    }

    .treatment-strip {
      align-items: center;
      display: flex;
      gap: 0.5rem;
      list-style: none;
      margin: 0 0 1rem;
      overflow-x: auto;
      padding: 0 0 0.2rem;
      scrollbar-width: none;
    }

    .treatment-strip::-webkit-scrollbar {
      display: none;
    }

    .treatment-strip li {
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(192, 178, 131, 0.22);
      border-radius: 999px;
      color: var(--charcoal);
      flex: 0 0 auto;
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      line-height: 1;
      padding: 0.68rem 0.82rem;
      text-transform: uppercase;
    }

    .booking-shell {
      background: #304552;
      border: 1px solid rgba(192, 178, 131, 0.32);
      border-radius: 8px;
      box-shadow:
        0 20px 55px rgba(54, 69, 79, 0.16),
        0 1px 0 rgba(255, 255, 255, 0.9) inset;
      height: clamp(720px, calc(100svh - 240px), 980px);
      min-height: 720px;
      overflow: hidden;
      position: relative;
    }

    .booking-shell-bar {
      align-items: center;
      background: linear-gradient(90deg, rgba(54, 69, 79, 0.96), rgba(61, 78, 90, 0.96));
      border-bottom: 1px solid rgba(192, 178, 131, 0.24);
      color: rgba(253, 253, 253, 0.78);
      display: flex;
      font-size: 0.74rem;
      font-weight: 700;
      justify-content: space-between;
      letter-spacing: 0.08em;
      min-height: 38px;
      padding: 0 1rem;
      text-transform: uppercase;
    }

    .booking-shell-title {
      align-items: center;
      display: inline-flex;
      gap: 0.55rem;
    }

    .booking-shell-title span {
      background: var(--soma-gold);
      border-radius: 999px;
      box-shadow: 0 0 0 4px rgba(192, 178, 131, 0.16);
      height: 0.44rem;
      width: 0.44rem;
    }

    .booking-frame {
      background: #ffffff;
      border: 0;
      height: calc(100% - 38px);
      position: relative;
      width: 100%;
      z-index: 2;
    }

    .booking-loading {
      align-items: center;
      background: linear-gradient(180deg, #ffffff 0%, #f8f6f0 100%);
      color: var(--secondary-text);
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      inset: 38px 0 0;
      justify-content: center;
      opacity: 1;
      pointer-events: none;
      position: absolute;
      transition: opacity 220ms ease;
      z-index: 3;
    }

    .booking-loading span {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .booking-shell.is-loaded .booking-loading {
      opacity: 0;
      visibility: hidden;
    }

    .loading-spinner {
      animation: spin 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
      border: 2px solid rgba(192, 178, 131, 0.15);
      border-radius: 50%;
      border-top-color: var(--soma-gold);
      height: 32px;
      width: 32px;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    .booking-assistance {
      align-items: center;
      color: var(--secondary-text);
      display: flex;
      flex-wrap: wrap;
      font-size: 0.9rem;
      gap: 0.85rem 1.25rem;
      justify-content: center;
      padding: 1.05rem 0 0.2rem;
    }

    .booking-assistance span {
      opacity: 0.7;
    }

    .booking-assistance a {
      align-items: center;
      color: var(--charcoal);
      display: inline-flex;
      gap: 0.4rem;
      text-decoration: none;
      transition: color 180ms ease;
    }

    .booking-assistance a:hover {
      color: var(--soma-gold);
    }

    @media (max-width: 860px) {
      .booking-header {
        grid-template-columns: 1fr;
      }

      .booking-actions {
        justify-content: flex-start;
      }
    }

    @media (max-width: 640px) {
      .booking-page {
        padding: 0.9rem;
      }

      .booking-copy h1 {
        font-size: 2.25rem;
      }

      .booking-copy p:not(.booking-overline) {
        font-size: 0.94rem;
      }

      .booking-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        width: 100%;
      }

      .booking-action {
        justify-content: center;
        padding-left: 0.75rem;
        padding-right: 0.75rem;
      }

      .booking-shell {
        height: 78svh;
        min-height: 650px;
      }

      .booking-shell-bar {
        font-size: 0.66rem;
        padding: 0 0.75rem;
      }

      .booking-assistance {
        align-items: flex-start;
        flex-direction: column;
        padding-left: 0.1rem;
      }
    }
  </style>

  <script>
    const bookingFrame = document.querySelector("[data-booking-frame]");
    const bookingShell = document.querySelector("[data-booking-shell]");
    const revealBookingFrame = () => {
      bookingShell?.classList.add("is-loaded");
    };

    bookingFrame?.addEventListener("load", revealBookingFrame, { once: true });
    window.setTimeout(revealBookingFrame, 3200);
  </script>
</MainLayout>
