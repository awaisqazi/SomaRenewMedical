---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contact Us">
  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <section class="bg-bone">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="flex items-center justify-between py-4 border-b border-line font-mono text-[0.62rem] sm:text-[0.68rem] tracking-[0.18em] uppercase text-ink/45">
        <span>Contact</span>
        <span class="hidden sm:inline">Mon to Sat</span>
        <span>Naperville, IL</span>
      </div>

      <div class="pt-16 md:pt-24 pb-12 md:pb-16 max-w-4xl">
        <p class="label reveal mb-7">
          <span class="inline-block w-9 h-px bg-gold/60"></span> Get in Touch
        </p>
        <h1 class="reveal d-1 font-serif text-ink leading-[0.96] text-[clamp(2.6rem,11vw,3.75rem)] sm:text-7xl xl:text-[5.4rem]">
          Let's start a <span class="accent-word">conversation.</span>
        </h1>
        <p class="reveal d-2 mt-7 max-w-xl text-lg text-secondary-text leading-relaxed">
          Questions about a treatment, pricing or what's right for you? Send a
          note. We read every message and reply quickly.
        </p>
      </div>
    </div>
  </section>

  <!-- ══ FORM + INFO ═══════════════════════════════════════════════════ -->
  <section class="section bg-cream border-t border-line">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="grid lg:grid-cols-12 gap-y-16 lg:gap-x-20">
        <!-- Form -->
        <div class="lg:col-span-7 reveal">
          <p class="index-label mb-5"><span class="num">01</span> &nbsp;·&nbsp;Send a Message</p>
          <div class="reveal-line h-px bg-line mb-10"></div>

          <form action="#" method="POST" class="space-y-9">
            <div class="grid sm:grid-cols-2 gap-9">
              <div class="field">
                <label class="field-label" for="name">Your Name</label>
                <input class="field-input" id="name" name="name" type="text" autocomplete="name" placeholder="John Smith" />
              </div>
              <div class="field">
                <label class="field-label" for="email">Email Address</label>
                <input class="field-input" id="email" name="email" type="email" autocomplete="email" placeholder="john@example.com" />
              </div>
            </div>
            <div class="field">
              <label class="field-label" for="phone">Phone Number</label>
              <input class="field-input" id="phone" name="phone" type="tel" autocomplete="tel" placeholder="(630) 555-0150" />
            </div>
            <div class="field">
              <label class="field-label" for="message">Your Message</label>
              <textarea class="field-input resize-none" id="message" name="message" rows="4" placeholder="How can we help you?"></textarea>
            </div>
            <button type="submit" class="btn-primary">
              Send Message
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
            </button>
          </form>
        </div>

        <!-- Info -->
        <div class="lg:col-span-5 reveal d-1">
          <p class="index-label mb-5"><span class="num">02</span> &nbsp;·&nbsp;Visit & Details</p>
          <div class="reveal-line h-px bg-line mb-10"></div>

          <div class="space-y-8">
            <div>
              <p class="field-label mb-2">Address</p>
              <a
                href="https://maps.google.com/?q=1867+Bay+Scott+Cir,+Naperville,+IL+60540"
                target="_blank" rel="noopener noreferrer"
                class="font-serif text-2xl text-ink hover:text-gold-deep transition-colors leading-snug block"
              >
                1867 Bay Scott Cir<br />Naperville, IL 60540
              </a>
            </div>

            <div class="grid grid-cols-2 gap-8 pt-8 border-t border-line">
              <div>
                <p class="field-label mb-2">Phone</p>
                <a href="tel:+16305550150" class="font-serif text-xl text-ink hover:text-gold-deep transition-colors">(630) 555-0150</a>
              </div>
              <div>
                <p class="field-label mb-2">Email</p>
                <a href="mailto:contact@somarenewmedical.com" class="text-ink hover:text-gold-deep transition-colors break-words">contact@somarenewmedical.com</a>
              </div>
            </div>

            <div class="pt-8 border-t border-line">
              <p class="field-label mb-3">Hours</p>
              <ul class="space-y-1.5 text-secondary-text">
                <li class="flex justify-between max-w-xs"><span>Monday to Friday</span><span class="text-ink">9 AM to 6 PM</span></li>
                <li class="flex justify-between max-w-xs"><span>Saturday</span><span class="text-ink">10 AM to 4 PM</span></li>
                <li class="flex justify-between max-w-xs"><span>Sunday</span><span class="text-ink/50">Closed</span></li>
              </ul>
            </div>

            <div class="map-frame mt-2">
              <iframe
                allowfullscreen=""
                class="w-full h-[260px]"
                loading="lazy"
                title="SomaRenew Medical location map"
                src="https://maps.google.com/maps?q=1867+Bay+Scott+Cir,+Naperville,+IL+60540&t=&z=15&ie=UTF8&iwloc=&output=embed"
                style="border: 0"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .field-label {
    display: block;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .field-input {
    width: 100%;
    margin-top: 0.6rem;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--line-strong);
    padding: 0.6rem 0;
    color: var(--ink);
    font-family: 'Raleway', sans-serif;
    font-size: 1.05rem;
    transition: border-color 0.35s ease;
  }
  .field-input::placeholder { color: rgba(91, 103, 112, 0.5); }
  .field-input:focus {
    outline: none;
    border-bottom-color: var(--gold-deep);
  }
  .map-frame {
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    filter: grayscale(0.25) contrast(0.95);
  }
</style>
