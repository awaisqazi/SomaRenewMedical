---
import MainLayout from "../layouts/MainLayout.astro";

const steps = [
  {
    id: 1,
    label: "Digital Discovery",
    headline: "Effortless scheduling.",
    body: "Browse our curated service menu from the comfort of home. Select your time, secure your appointment with a deposit, and receive instant confirmation, seamlessly.",
    tone: "ink",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01",
  },
  {
    id: 2,
    label: "Digital Intake",
    headline: "Your story, before you arrive.",
    body: "No clipboards. No waiting. Complete your comprehensive health history and consent forms digitally through our secure portal, before you ever step through the door.",
    tone: "sage",
    icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z",
  },
  {
    id: 3,
    label: "Sanctuary Arrival",
    headline: "Step into serenity.",
    body: "Arrive at SomaRenew, where clinical excellence meets a calmer kind of space. Enjoy complimentary amenities while we prepare your treatment suite.",
    tone: "sand",
    icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z M3 12h.01",
  },
  {
    id: 4,
    label: "Expert Consultation",
    headline: "Collaborative care.",
    body: "Sit down with our specialists to review your intake. We listen to your goals first, then design a plan (GLP-1 therapy or peptide therapy) built around them.",
    tone: "dusty",
    icon: "M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4zm6 0a4 4 0 10-3-6.5",
  },
  {
    id: 5,
    label: "Seamless Checkout",
    headline: "Integrated wellness.",
    body: "Checkout is frictionless. Your treatment plan, future appointments and membership perks are all managed centrally in your patient portal.",
    tone: "gold",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];

const toneClass = {
  ink: "scene-ink",
  sage: "scene-sage",
  sand: "scene-sand",
  dusty: "scene-dusty",
  gold: "scene-gold",
};

const bookingUrl =
  "https://partner.pabau.com/online-bookings/soma-renew-medical?groupCategory=0&category=195676&serviceType=0";
---

<MainLayout title="The Experience">
  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <section class="bg-bone">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="flex items-center justify-between py-4 border-b border-line font-mono text-[0.62rem] sm:text-[0.68rem] tracking-[0.18em] uppercase text-ink/45">
        <span>The Concierge Experience</span>
        <span class="hidden sm:inline">Five steps</span>
        <span>Designed around you</span>
      </div>

      <div class="pt-20 md:pt-28 pb-20 md:pb-28 text-center">
        <p class="label reveal justify-center mb-7">
          <span class="inline-block w-9 h-px bg-gold/60"></span> The Experience
        </p>
        <h1 class="reveal d-1 font-serif text-ink leading-[0.95] text-[clamp(2.7rem,12vw,3.75rem)] sm:text-7xl xl:text-[7rem]">
          Your journey,<br /><span class="accent-word">reimagined.</span>
        </h1>
        <p class="reveal d-2 mt-8 max-w-xl mx-auto text-lg text-secondary-text leading-relaxed">
          From digital discovery to integrated wellness: healthcare designed
          around you, at every step.
        </p>
        <div class="reveal d-3 mt-10 flex justify-center">
          <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Begin Your Journey
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ JOURNEY · desktop sticky ══════════════════════════════════════ -->
  <section class="journey-section hidden lg:block bg-cream border-t border-line">
    <div class="mx-auto max-w-[1400px] px-8">
      <div class="grid grid-cols-12 gap-16">
        <!-- Sticky scenes -->
        <div class="col-span-5">
          <div class="sticky top-28 h-[72vh] py-4">
            <div class="relative w-full h-full">
              {steps.map((step, index) => (
                <div
                  class={`journey-image absolute inset-0 transition-all duration-700 ease-out ${index === 0 ? "opacity-100 scale-100" : "opacity-0 scale-[0.97]"}`}
                  data-step={step.id}
                >
                  <div class={`scene ${toneClass[step.tone]} relative h-full rounded-[4px] overflow-hidden flex flex-col justify-between p-10`}>
                    <div class="flex items-start justify-between">
                      <span class="font-mono text-[0.66rem] tracking-[0.18em] uppercase scene-label">Step 0{step.id}</span>
                      <svg class="w-9 h-9 scene-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.25" d={step.icon} />
                      </svg>
                    </div>
                    <div>
                      <span class="scene-numeral font-serif leading-none">{step.id}</span>
                      <p class="font-serif text-3xl scene-title mt-2">{step.label}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Scrolling content -->
        <div class="col-span-7 py-28">
          {steps.map((step, index) => (
            <div class="journey-step min-h-[78vh] flex items-center" data-step={step.id}>
              <div class={`journey-step-content transition-all duration-700 ${index === 0 ? "opacity-100 translate-y-0" : "opacity-0 translate-y-8"}`}>
                <p class="index-label mb-5">
                  <span class="num">0{step.id}</span> &nbsp;·&nbsp;{step.label}
                </p>
                <div class="h-px bg-line mb-8 w-24"></div>
                <h2 class="font-serif text-5xl xl:text-6xl text-ink leading-[1.02] mb-6">{step.headline}</h2>
                <p class="text-xl text-secondary-text leading-relaxed max-w-xl">{step.body}</p>
                <div class="flex items-center gap-2 mt-10">
                  {steps.map((_, i) => (
                    <div class={`h-px rounded-full transition-all duration-500 ${i < step.id ? "w-10 bg-gold-deep" : "w-5 bg-line"}`}></div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ JOURNEY · mobile stack ════════════════════════════════════════ -->
  <section class="journey-mobile lg:hidden section bg-cream border-t border-line">
    <div class="mx-auto max-w-lg px-5">
      <div class="mb-14 text-center">
        <p class="index-label reveal justify-center">The Journey</p>
        <h2 class="reveal d-1 font-serif text-4xl text-ink mt-4">Five steps to wellness</h2>
      </div>

      <div class="space-y-12">
        {steps.map((step, index) => (
          <div class="reveal">
            <div class={`scene ${toneClass[step.tone]} rounded-[4px] overflow-hidden flex flex-col justify-between p-7 h-56 mb-6`}>
              <div class="flex items-start justify-between">
                <span class="font-mono text-[0.62rem] tracking-[0.18em] uppercase scene-label">Step 0{step.id}</span>
                <svg class="w-8 h-8 scene-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.25" d={step.icon} />
                </svg>
              </div>
              <span class="scene-numeral font-serif leading-none text-7xl">{step.id}</span>
            </div>
            <p class="index-label mb-3"><span class="num">0{step.id}</span> &nbsp;·&nbsp;{step.label}</p>
            <h3 class="font-serif text-3xl text-ink mb-3">{step.headline}</h3>
            <p class="text-secondary-text leading-relaxed">{step.body}</p>
            {index < steps.length - 1 && <div class="flex justify-center mt-10"><div class="w-px h-12 bg-line"></div></div>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ CLOSING ═══════════════════════════════════════════════════════ -->
  <section class="on-dark relative bg-ink text-cream overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[var(--soma-gold)]/40 to-transparent"></div>
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 section text-center">
      <p class="label label--light reveal justify-center mb-7">No clipboards. No waiting.</p>
      <h2 class="reveal d-1 font-serif text-5xl md:text-6xl lg:text-7xl text-cream leading-[1] max-w-3xl mx-auto">
        Begin in under <span class="accent-word accent-word--light">five minutes.</span>
      </h2>
      <p class="reveal d-2 mt-8 max-w-xl mx-auto text-cream/55 text-lg leading-relaxed">
        Choose your time, secure it with a deposit, and complete intake from your
        couch. The rest, we'll handle in person.
      </p>
      <div class="reveal d-2 mt-10 flex justify-center">
        <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-gold">
          Schedule Your Consultation
        </a>
      </div>
      <div class="reveal d-3 mt-14 flex flex-wrap justify-center gap-x-10 gap-y-3 font-mono text-[0.66rem] tracking-[0.12em] uppercase text-cream/40">
        <span>Secure Booking</span>
        <span class="text-gold/40">·</span>
        <span>Instant Confirmation</span>
        <span class="text-gold/40">·</span>
        <span>Physician-Guided Care</span>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Editorial "scene" panels (stand-ins for forthcoming photography) */
  .scene { border: 1px solid var(--line); }
  .scene-numeral { font-size: clamp(7rem, 16vw, 13rem); }

  .scene-ink {
    background: linear-gradient(150deg, #283036 0%, #1B2227 100%);
    border-color: rgba(192, 178, 131, 0.22);
  }
  .scene-ink .scene-label, .scene-ink .scene-icon { color: rgba(192, 178, 131, 0.85); }
  .scene-ink .scene-numeral { color: rgba(192, 178, 131, 0.9); }
  .scene-ink .scene-title { color: var(--cream); }

  .scene-sand {
    background: linear-gradient(150deg, #EFE7D8 0%, #E4D9C4 100%);
  }
  .scene-sand .scene-label, .scene-sand .scene-icon, .scene-sand .scene-title { color: var(--ink); }
  .scene-sand .scene-numeral { color: rgba(142, 123, 67, 0.55); }

  .scene-sage {
    background: linear-gradient(150deg, #8A9A66 0%, #6F8049 100%);
  }
  .scene-sage .scene-label, .scene-sage .scene-icon, .scene-sage .scene-title { color: #FBF8F2; }
  .scene-sage .scene-numeral { color: rgba(251, 248, 242, 0.85); }

  .scene-dusty {
    background: linear-gradient(150deg, #7E8E9C 0%, #5E6F7E 100%);
  }
  .scene-dusty .scene-label, .scene-dusty .scene-icon, .scene-dusty .scene-title { color: #FBF8F2; }
  .scene-dusty .scene-numeral { color: rgba(251, 248, 242, 0.85); }

  .scene-gold {
    background: linear-gradient(150deg, #CDBF92 0%, #B6A671 100%);
  }
  .scene-gold .scene-label, .scene-gold .scene-icon, .scene-gold .scene-title { color: var(--ink); }
  .scene-gold .scene-numeral { color: rgba(27, 34, 39, 0.5); }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const journeySteps = document.querySelectorAll(".journey-section .journey-step");
    const journeyImages = document.querySelectorAll(".journey-section .journey-image");
    const journeyContent = document.querySelectorAll(".journey-section .journey-step-content");

    if (journeySteps.length) {
      let active = -1;
      const setActive = (idx: number) => {
        if (idx === active) return;
        active = idx;
        journeyImages.forEach((img, i) => {
          const el = img as HTMLElement;
          el.classList.toggle("opacity-100", i === idx);
          el.classList.toggle("scale-100", i === idx);
          el.classList.toggle("opacity-0", i !== idx);
          el.classList.toggle("scale-[0.97]", i !== idx);
        });
        journeyContent.forEach((c, i) => {
          const el = c as HTMLElement;
          el.classList.toggle("opacity-100", i === idx);
          el.classList.toggle("translate-y-0", i === idx);
          el.classList.toggle("opacity-0", i !== idx);
          el.classList.toggle("translate-y-8", i !== idx);
        });
      };

      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = parseInt((entry.target as HTMLElement).dataset.step || "1") - 1;
              setActive(id);
            }
          });
        },
        { threshold: 0.5, rootMargin: "-20% 0px -20% 0px" }
      );
      journeySteps.forEach((s) => obs.observe(s));
      setActive(0);
    }
  });
</script>
