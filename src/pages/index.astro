---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import heroImage from "../images/hero.png";

const pillars = [
  {
    n: "01",
    title: "FDA-approved, evidence-led",
    body: "Only regulated medications and medical-grade protocols (GLP-1 therapy, peptides) chosen for what the science actually supports.",
  },
  {
    n: "02",
    title: "Built around one body: yours",
    body: "No protocols off a shelf. Comprehensive labs and a physician's read of your history shape a plan that fits how you actually live.",
  },
  {
    n: "03",
    title: "High-tech, genuinely high-touch",
    body: "Modern diagnostics and body contouring, paired with unhurried, one-to-one attention from the people overseeing your care.",
  },
  {
    n: "04",
    title: "Results that outlast the program",
    body: "We're less interested in a number on a scale and more in the habits, energy and confidence that keep it there.",
  },
];

const modalities = [
  { name: "Medical Weight Loss", note: "GLP-1 consultation & monthly medication", from: "from $199" },
  { name: "Body Contouring", note: "CoolSculpting & U-Shape 2 sculpting", from: "from $175" },
  { name: "Peptide Therapy", note: "Injectable & nasal-spray protocols", from: "from $99" },
  { name: "IV Hydration", note: "Targeted drips & NAD+ boosters", from: "from $49" },
  { name: "Nutrition Counseling", note: "Assessments & follow-up sessions", from: "from $75" },
  { name: "Signature Packages", note: "Multi-month transformation programs", from: "from $599" },
];

const faqs = [
  {
    q: "Are your treatments safe?",
    a: "Yes. We use only FDA-approved medications and medical-grade equipment, every plan overseen by a board-certified physician.",
  },
  {
    q: "Do I need a referral or prior diagnosis?",
    a: "No referral is needed. We begin with a thorough health assessment and design a plan from there.",
  },
  {
    q: "How soon will I see results?",
    a: "Every journey differs, but most patients notice measurable changes within the first few weeks of consistent, supported care.",
  },
];
---

<MainLayout title="Home">
  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <section class="relative bg-bone overflow-hidden">
    <!-- Masthead micro-row -->
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="flex items-center justify-between py-4 border-b border-line font-mono text-[0.62rem] sm:text-[0.68rem] tracking-[0.18em] uppercase text-ink/45">
        <span>Naperville, Illinois</span>
        <span class="hidden sm:inline">Physician-led wellness</span>
        <span>Est. MMXXIV</span>
      </div>
    </div>

    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="grid lg:grid-cols-12 gap-y-12 lg:gap-x-12 items-center pt-12 md:pt-16 lg:pt-20 pb-16 md:pb-24">
        <!-- Copy -->
        <div class="lg:col-span-6 lg:pr-6">
          <p class="label reveal mb-7">
            <span class="inline-block w-9 h-px bg-gold/60"></span> SomaRenew Medical
          </p>
          <h1 class="reveal d-1 font-serif text-ink leading-[0.95] text-[clamp(2.35rem,8.8vw,3.1rem)] sm:text-7xl xl:text-[5.6rem] mb-8">
            The physician-led<br />
            path to <span class="accent-word">transformation.</span>
          </h1>
          <p class="reveal d-2 max-w-md text-lg text-secondary-text leading-relaxed mb-10">
            GLP-1 medications, peptide therapy and advanced body contouring,
            composed into one considered plan, and looked after by people who
            know your name.
          </p>
          <div class="reveal d-3 flex flex-col sm:flex-row gap-4">
            <a href="/consultation" class="btn-primary">
              Book a Consultation
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
            </a>
            <a href="/services" class="btn-secondary">View the Menu</a>
          </div>
        </div>

        <!-- Image panel -->
        <div class="lg:col-span-6 reveal d-2">
          <figure class="hero-frame relative">
            <Image
              src={heroImage}
              alt="A calm treatment space at SomaRenew Medical"
              class="hero-photo w-full h-[48vh] sm:h-[60vh] lg:h-[78vh] object-cover"
              widths={[640, 960, 1400]}
              sizes="(min-width: 1024px) 50vw, 100vw"
              format="webp"
              quality={70}
              loading="eager"
              fetchpriority="high"
            />
            <div class="hero-tint absolute inset-0"></div>
            <!-- floating credential chip -->
            <figcaption class="hero-chip">
              <span class="font-mono text-[0.6rem] tracking-[0.18em] uppercase text-ink/55">Overseen by</span>
              <span class="block font-serif text-xl text-ink leading-tight mt-1">Dr. Youssef Hedroug, MD</span>
              <span class="font-mono text-[0.6rem] tracking-[0.14em] uppercase text-gold-deep">Board-Certified · ABEM</span>
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ PHILOSOPHY ════════════════════════════════════════════════════ -->
  <section class="section bg-cream">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="grid lg:grid-cols-12 gap-y-10 lg:gap-x-16">
        <div class="lg:col-span-4">
          <p class="index-label reveal"><span class="num">I</span> &nbsp;·&nbsp;Philosophy</p>
          <div class="reveal-line h-px bg-line mt-5 mb-8"></div>
          <p class="reveal d-1 section-index text-7xl md:text-8xl">Soma</p>
        </div>
        <div class="lg:col-span-8 lg:pl-4">
          <p class="reveal font-serif text-[1.9rem] sm:text-4xl lg:text-[2.9rem] leading-[1.2] text-ink">
            We treat weight, hormones and energy as one connected system,
            because your body never experienced them as separate problems.
            <span class="text-ink/45">Where personalized medicine meets a calmer kind of care, lasting change becomes the natural outcome, not the hard-won exception.</span>
          </p>
          <a href="/aboutus" class="link-arrow reveal d-1 mt-10">
            Our approach to care
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ APPROACH · numbered index ═════════════════════════════════════ -->
  <section class="section bg-bone">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="grid lg:grid-cols-12 gap-y-12 lg:gap-x-16">
        <!-- Sticky heading -->
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <p class="index-label reveal"><span class="num">II</span> &nbsp;·&nbsp;The Approach</p>
            <div class="reveal-line h-px bg-line mt-5 mb-8"></div>
            <h2 class="reveal d-1 font-serif text-4xl md:text-5xl leading-[1.05] text-ink">
              Four principles<br />we don't<br /><span class="accent-word">compromise on.</span>
            </h2>
          </div>
        </div>

        <!-- List -->
        <div class="lg:col-span-8">
          <ul>
            {pillars.map((p, i) => (
              <li class={`reveal d-${i + 1} group grid grid-cols-[auto_1fr] gap-x-6 sm:gap-x-10 py-9 ${i === 0 ? "border-t" : ""} border-b border-line`}>
                <span class="font-mono text-sm text-gold-deep pt-2.5">{p.n}</span>
                <div>
                  <h3 class="font-serif text-2xl sm:text-3xl text-ink mb-3 transition-transform duration-500 group-hover:translate-x-1">
                    {p.title}
                  </h3>
                  <p class="text-secondary-text leading-relaxed max-w-xl">{p.body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ MODALITIES preview ════════════════════════════════════════════ -->
  <section class="section bg-cream">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div>
          <p class="index-label reveal"><span class="num">III</span> &nbsp;·&nbsp;The Menu</p>
          <h2 class="reveal d-1 font-serif text-4xl md:text-5xl text-ink mt-5">What we offer</h2>
        </div>
        <a href="/services" class="link-arrow reveal d-1">
          Full service menu & pricing
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
        </a>
      </div>

      <div class="border-t border-line">
        {modalities.map((m, i) => (
          <a href="/services" class={`reveal d-${(i % 4) + 1} group flex items-center justify-between gap-4 py-7 border-b border-line transition-colors duration-300 hover:bg-bone/60 -mx-4 px-4`}>
            <div class="flex items-baseline gap-4 sm:gap-8 min-w-0">
              <span class="font-mono text-xs text-gold-deep/70 shrink-0">0{i + 1}</span>
              <h3 class="font-serif text-2xl sm:text-4xl text-ink truncate transition-transform duration-500 group-hover:translate-x-2">
                {m.name}
              </h3>
            </div>
            <div class="flex items-center gap-5 sm:gap-10 shrink-0">
              <span class="hidden md:block text-sm text-secondary-text max-w-[18rem] text-right">{m.note}</span>
              <span class="font-mono text-[0.7rem] tracking-[0.12em] uppercase text-ink/55 whitespace-nowrap">{m.from}</span>
              <svg class="w-5 h-5 text-gold-deep opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M5 12h14m0 0l-6-6m6 6l-6 6"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ FAQ ═══════════════════════════════════════════════════════════ -->
  <section class="section bg-bone">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="grid lg:grid-cols-12 gap-y-10 lg:gap-x-16">
        <div class="lg:col-span-4">
          <p class="index-label reveal"><span class="num">IV</span> &nbsp;·&nbsp;Questions</p>
          <h2 class="reveal d-1 font-serif text-4xl md:text-5xl text-ink mt-5">
            Before you<br />begin.
          </h2>
        </div>
        <div class="lg:col-span-8">
          {faqs.map((f, i) => (
            <div
              x-data="{ open: false }"
              class={`faq reveal d-${i + 1} ${i === 0 ? "border-t" : ""} border-b border-line`}
            >
              <button
                type="button"
                @click="open = !open"
                :aria-expanded="open"
                class="group w-full flex items-start justify-between gap-6 py-7 text-left"
              >
                <span class="flex items-baseline gap-5">
                  <span class="font-mono text-xs text-gold-deep/70">0{i + 1}</span>
                  <span class="font-serif text-2xl sm:text-3xl text-ink transition-colors duration-300 group-hover:text-gold-deep">{f.q}</span>
                </span>
                <span class="faq-plus relative mt-2 w-4 h-4 shrink-0" :class="{ 'is-open': open }"></span>
              </button>
              <div class="faq-body" :class="{ 'is-open': open }">
                <div class="faq-inner">
                  <p class="pb-8 pl-0 sm:pl-[2.6rem] text-secondary-text leading-relaxed max-w-2xl">{f.a}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CLOSING INVITATION ════════════════════════════════════════════ -->
  <section class="on-dark relative bg-ink text-cream overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[var(--soma-gold)]/40 to-transparent"></div>
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 section">
      <div class="grid lg:grid-cols-12 gap-y-12 lg:gap-x-16 items-center">
        <div class="lg:col-span-7">
          <p class="label label--light reveal mb-7">
            <span class="inline-block w-9 h-px bg-soma-gold/60"></span> Begin Today
          </p>
          <h2 class="reveal d-1 font-serif text-5xl sm:text-6xl lg:text-7xl leading-[0.98] text-cream">
            Your first consultation<br />is on us.
          </h2>
          <p class="reveal d-2 mt-8 max-w-md text-cream/55 text-lg leading-relaxed">
            Spend an unhurried hour with our team. We'll review your goals, your
            labs and your options, and you'll leave with a clear, honest picture
            of what's possible.
          </p>
        </div>
        <div class="lg:col-span-5 lg:pl-8">
          <div class="reveal d-2 flex flex-col gap-4">
            <a href="/consultation" class="btn-gold w-full">Book My Free Consultation</a>
            <a href="/services" class="btn-secondary btn-secondary--light w-full">Explore Treatments</a>
          </div>
          <div class="reveal d-3 mt-10 grid grid-cols-3 gap-4 pt-8 border-t border-line-on-dark">
            {["Physician-guided", "Personalized", "Lasting results"].map((t) => (
              <span class="font-mono text-[0.6rem] sm:text-[0.66rem] tracking-[0.1em] uppercase text-cream/45 leading-snug">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Hero image framing & warm tint */
  .hero-frame {
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 50px 90px -55px rgba(27, 34, 39, 0.5);
  }
  .hero-photo {
    animation: kenburns 28s ease-in-out infinite alternate;
    transform-origin: 60% 40%;
  }
  .hero-tint {
    background: linear-gradient(180deg, rgba(27, 34, 39, 0.05) 0%, rgba(27, 34, 39, 0) 35%, rgba(27, 34, 39, 0.18) 100%),
                linear-gradient(120deg, rgba(192, 178, 131, 0.12), transparent 55%);
    pointer-events: none;
  }
  @keyframes kenburns {
    0% { transform: scale(1); }
    100% { transform: scale(1.06); }
  }
  .hero-chip {
    position: absolute;
    left: 1.1rem;
    bottom: 1.1rem;
    background: rgba(251, 248, 242, 0.92);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line);
    border-radius: 3px;
    padding: 0.85rem 1.1rem;
    max-width: 78%;
  }

  /* FAQ accordion */
  .faq-plus::before,
  .faq-plus::after {
    content: '';
    position: absolute;
    background: var(--gold-deep);
    transition: transform 0.35s ease, opacity 0.35s ease;
  }
  .faq-plus::before { top: 50%; left: 0; width: 100%; height: 1.5px; transform: translateY(-50%); }
  .faq-plus::after { left: 50%; top: 0; width: 1.5px; height: 100%; transform: translateX(-50%); }
  .faq-plus.is-open::after { transform: translateX(-50%) scaleY(0); opacity: 0; }

  .faq-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .faq-body.is-open { grid-template-rows: 1fr; }
  .faq-inner { overflow: hidden; min-height: 0; }

  @media (prefers-reduced-motion: reduce) {
    .hero-photo { animation: none; }
  }
</style>
