---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import youssefImage from "../images/youssef.png";

const credentials = [
  "ABEM Board Certified",
  "Emergency Medicine",
  "Rush Medical College",
];
---

<MainLayout title="About Us">
  <!-- ══ HERO ══════════════════════════════════════════════════════════ -->
  <section class="bg-bone">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="flex items-center justify-between py-4 border-b border-line font-mono text-[0.62rem] sm:text-[0.68rem] tracking-[0.18em] uppercase text-ink/45">
        <span>About SomaRenew</span>
        <span class="hidden sm:inline">Our story</span>
        <span>Est. MMXXIV</span>
      </div>

      <div class="pt-16 md:pt-24 pb-16 md:pb-20 max-w-5xl">
        <p class="label reveal mb-7">
          <span class="inline-block w-9 h-px bg-gold/60"></span> Who We Are
        </p>
        <h1 class="reveal d-1 font-serif text-ink leading-[0.96] text-5xl sm:text-7xl xl:text-[5.4rem]">
          Redefining wellness through
          <span class="accent-word">innovation</span> &amp; <span class="accent-word">compassionate care.</span>
        </h1>
      </div>
    </div>
  </section>

  <!-- ══ MISSION / VISION ══════════════════════════════════════════════ -->
  <section class="section bg-cream border-t border-line">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="grid md:grid-cols-2 gap-x-16 gap-y-14">
        <div class="reveal">
          <p class="index-label mb-5"><span class="num">01</span> &nbsp;·&nbsp;Our Mission</p>
          <div class="reveal-line h-px bg-line mb-8"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-ink leading-[1.1] mb-6">Empowering your journey</h2>
          <p class="text-secondary-text leading-relaxed text-lg">
            To empower individuals through personalized medical care (FDA-approved
            medications, state-of-the-art technology and science-based hydration),
            promoting sustainable health, vitality and lasting transformation.
          </p>
        </div>
        <div class="reveal d-1">
          <p class="index-label mb-5"><span class="num">02</span> &nbsp;·&nbsp;Our Vision</p>
          <div class="reveal-line h-px bg-line mb-8"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-ink leading-[1.1] mb-6">The premier destination</h2>
          <p class="text-secondary-text leading-relaxed text-lg">
            To be the premier destination for personalized, medically guided care,
            where innovation, FDA-approved treatments and genuine compassion come
            together to redefine wellness and inspire lifelong confidence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ MEET THE SPECIALIST ═══════════════════════════════════════════ -->
  <section class="section bg-bone border-t border-line">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="mb-14">
        <p class="index-label reveal"><span class="num">03</span> &nbsp;·&nbsp;Expert Care</p>
        <h2 class="reveal d-1 font-serif text-4xl md:text-6xl text-ink mt-5">Meet the specialist</h2>
      </div>

      <div class="grid lg:grid-cols-12 gap-y-10 lg:gap-x-14 items-stretch">
        <!-- Photo -->
        <div class="lg:col-span-5 reveal">
          <figure class="profile-frame relative">
            <Image
              src={youssefImage}
              alt="Dr. Youssef Hedroug, MD"
              class="w-full h-[460px] sm:h-[560px] lg:h-full object-cover object-top"
              widths={[480, 720, 1000]}
              sizes="(min-width: 1024px) 42vw, 100vw"
              format="webp"
              quality={74}
              loading="lazy"
            />
            <figcaption class="absolute left-4 bottom-4 bg-cream/92 backdrop-blur-sm border border-line rounded-[3px] px-4 py-2">
              <span class="font-mono text-[0.58rem] tracking-[0.18em] uppercase text-gold-deep">Board Certified</span>
            </figcaption>
          </figure>
        </div>

        <!-- Bio -->
        <div class="lg:col-span-7 lg:pl-6 flex flex-col justify-center reveal d-1">
          <p class="label mb-6">Board-Certified Physician</p>
          <h3 class="font-serif text-5xl md:text-6xl lg:text-7xl text-ink leading-[0.95]">
            Dr. Youssef<br /><span class="accent-word">Hedroug</span>
          </h3>
          <p class="mt-5 font-mono text-sm tracking-[0.08em] uppercase text-secondary-text">MD, Emergency Medicine</p>

          <div class="h-px bg-line my-9"></div>

          <p class="text-secondary-text leading-relaxed text-lg max-w-2xl">
            Dr. Hedroug is a board-certified emergency medicine physician with
            extensive clinical experience across multiple hospital systems. A
            graduate of <strong class="text-ink font-semibold">Rush Medical College</strong>,
            he is certified by the <strong class="text-ink font-semibold">American Board of
            Emergency Medicine</strong> and holds active licenses across Illinois,
            Texas, Michigan, New York and Iowa. His background in acute care and
            rapid patient assessment brings a uniquely evidence-based approach to
            personalized wellness and medical weight management.
          </p>

          <div class="mt-9 flex flex-wrap gap-3">
            {credentials.map((c) => (
              <span class="inline-flex items-center gap-2 px-4 py-2 border border-line rounded-full font-mono text-[0.66rem] tracking-[0.08em] uppercase text-ink/70">
                <span class="w-1 h-1 rounded-full bg-gold-deep"></span>{c}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CLOSING ═══════════════════════════════════════════════════════ -->
  <section class="on-dark relative bg-ink text-cream overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[var(--soma-gold)]/40 to-transparent"></div>
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8 section">
      <div class="grid lg:grid-cols-12 gap-y-10 lg:gap-x-16 items-center">
        <div class="lg:col-span-8">
          <p class="label label--light reveal mb-7">Care that listens first</p>
          <h2 class="reveal d-1 font-serif text-5xl md:text-6xl lg:text-7xl text-cream leading-[0.98]">
            Bring your goals.<br />We'll bring the <span class="accent-word accent-word--light">medicine.</span>
          </h2>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <p class="reveal d-2 text-cream/55 leading-relaxed mb-7 lg:ml-auto lg:max-w-xs">
            Sit down with Dr. Hedroug for an unhurried, honest conversation about
            what's actually right for you.
          </p>
          <a href="/consultation" class="btn-gold reveal d-2">Schedule a Consultation</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .profile-frame {
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px -50px rgba(27, 34, 39, 0.5);
    height: 100%;
  }
</style>
