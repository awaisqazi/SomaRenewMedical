---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/aboutus", label: "About" },
  { href: "/services", label: "Services" },
  { href: "/patientjourney", label: "The Experience" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);

const portalUrl = "https://partner.pabau.com/soma-renew-medical/login";
---

<div x-data="{ isOpen: false }" @keydown.escape.window="isOpen = false">
  <header class="site-header relative z-[102]">
    <div class="mx-auto max-w-[1400px] px-5 sm:px-8">
      <div class="flex items-center justify-between h-[72px] md:h-[84px]">
        <!-- Logo -->
        <a href="/" class="flex items-center group shrink-0" aria-label="SomaRenew Medical, home">
          <img
            src="/logo.png"
            alt="SomaRenew Medical"
            class="logo-img h-9 md:h-11 w-auto transition-transform duration-500 group-hover:scale-[1.03]"
          />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden lg:flex items-center gap-9">
          {links.map((l) => (
            <a
              href={l.href}
              class:list={["nav-link text-ink/70 hover:text-ink", { "is-active text-ink": isActive(l.href) }]}
            >
              {l.label}
            </a>
          ))}
        </nav>

        <!-- Desktop actions -->
        <div class="hidden lg:flex items-center gap-5">
          <a
            href={portalUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link text-ink/55 hover:text-gold-deep"
          >
            Portal
          </a>
          <a href="/consultation" class="btn-gold !min-h-[46px] !px-6 text-[0.72rem]">
            Book
          </a>
        </div>

        <!-- Mobile toggle -->
        <button
          @click="isOpen = !isOpen"
          class="lg:hidden relative w-11 h-11 flex items-center justify-center -mr-2 text-ink"
          :aria-expanded="isOpen"
          aria-label="Toggle menu"
        >
          <div class="hamburger w-6 h-4 relative flex flex-col justify-between" :class="{ 'is-open': isOpen }">
            <span class="block h-px w-full bg-current transition-all duration-300 origin-center"></span>
            <span class="block h-px w-full bg-current transition-all duration-300"></span>
            <span class="block h-px w-full bg-current transition-all duration-300 origin-center"></span>
          </div>
        </button>
      </div>
    </div>
    <div class="rule"></div>
  </header>

  <!-- Mobile full-panel menu -->
  <div
    x-show="isOpen"
    x-cloak
    class="mobile-menu fixed inset-0 z-[101] lg:hidden flex flex-col"
    x-transition:enter="transition ease-out duration-400"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-250"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
  >
    <div class="flex-1 flex flex-col justify-center px-7 pt-24 pb-10">
      <p class="index-label mb-8">Menu</p>
      <nav class="flex flex-col">
        {links.map((l, i) => (
          <a
            href={l.href}
            @click="isOpen = false"
            class:list={[
              "mob-link group flex items-baseline gap-4 py-4 border-b border-line",
              { "text-gold-deep": isActive(l.href), "text-ink": !isActive(l.href) },
            ]}
          >
            <span class="font-mono text-xs text-gold-deep/70 w-7">0{i + 1}</span>
            <span class="font-serif text-4xl sm:text-5xl leading-none transition-transform duration-300 group-hover:translate-x-1">
              {l.label}
            </span>
          </a>
        ))}
      </nav>

      <div class="mt-10 flex flex-col gap-3">
        <a href="/consultation" @click="isOpen = false" class="btn-gold w-full">Book a Consultation</a>
        <a
          href={portalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary w-full"
          @click="isOpen = false"
        >
          Patient Portal
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .site-header {
    background: rgba(251, 248, 242, 0.86);
    backdrop-filter: blur(14px) saturate(1.4);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
  }

  .hamburger.is-open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }

  .mobile-menu {
    background: var(--bone);
  }
</style>
