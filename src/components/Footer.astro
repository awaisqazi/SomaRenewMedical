---
const currentYear = new Date().getFullYear();

const nav = [
  { href: "/aboutus", label: "About" },
  { href: "/services", label: "Services" },
  { href: "/patientjourney", label: "The Experience" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="on-dark relative overflow-hidden bg-ink text-cream">
  <!-- top hairline + faint gold wash -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[var(--soma-gold)]/45 to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-[1400px] px-5 sm:px-8">
    <!-- Columns -->
    <div class="grid grid-cols-2 md:grid-cols-12 gap-y-12 gap-x-8 pt-20 md:pt-24 pb-16">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-5">
        <img
          src="/logo.png"
          alt="SomaRenew Medical"
          class="h-12 w-auto mb-6"
          style="filter: brightness(0) invert(1); opacity: 0.92;"
        />
        <p class="text-cream/45 leading-relaxed max-w-sm text-[0.95rem]">
          Physician-led weight loss, peptide therapy, hormone optimization and IV
          wellness, delivered with the calm and precision of a modern apothecary.
        </p>
      </div>

      <!-- Spacer -->
      <div class="hidden md:block md:col-span-1"></div>

      <!-- Nav -->
      <div class="md:col-span-2">
        <p class="index-label !text-cream/40 mb-6">Pages</p>
        <ul class="space-y-3.5">
          {nav.map((l) => (
            <li>
              <a href={l.href} class="text-cream/70 hover:text-soma-gold transition-colors duration-300 text-[0.95rem]">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-span-2 md:col-span-4">
        <p class="index-label !text-cream/40 mb-6">Visit & Contact</p>
        <div class="space-y-4 text-[0.95rem]">
          <a
            href="https://maps.google.com/?q=1867+Bay+Scott+Cir,+Naperville,+IL+60540"
            target="_blank"
            rel="noopener noreferrer"
            class="block text-cream/70 hover:text-soma-gold transition-colors duration-300 leading-relaxed"
          >
            1867 Bay Scott Cir<br />Naperville, IL 60540
          </a>
          <a href="tel:+16305550150" class="block text-cream/70 hover:text-soma-gold transition-colors duration-300">
            (630) 555-0150
          </a>
          <a href="mailto:contact@somarenewmedical.com" class="block text-cream/70 hover:text-soma-gold transition-colors duration-300">
            contact@somarenewmedical.com
          </a>
        </div>

        <!-- Social -->
        <div class="flex gap-3 mt-7">
          <a href="#" aria-label="Facebook" class="social-dot">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="social-dot">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-8 border-t border-line-on-dark flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="font-mono text-[0.66rem] tracking-[0.16em] uppercase text-cream/35 text-center">
        © {currentYear} SomaRenew Medical · Naperville, IL
      </p>
      <div class="flex gap-7 font-mono text-[0.66rem] tracking-[0.16em] uppercase">
        <a href="#" class="text-cream/35 hover:text-soma-gold transition-colors">Privacy</a>
        <a href="#" class="text-cream/35 hover:text-soma-gold transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .social-dot {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--line-on-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(243, 239, 230, 0.7);
    transition: all 0.35s ease;
  }
  .social-dot:hover {
    color: var(--ink);
    background: var(--soma-gold);
    border-color: var(--soma-gold);
  }
</style>
